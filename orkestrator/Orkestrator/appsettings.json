{
  "Orchestrator": {
    "RoomId": "philosophers-room",
    "HistoryLimit": 50,
    "MaxPhilosopherRepliesPerTurn": 2,
    "ModeratorSummaryWords": 90,
    "SimilarityThreshold": 0.72,
    "StateFilePath": "memory/room-state.json",
    "OpenClaw": {
      "BaseUrl": "http://localhost:18789",
      "SessionKey": "",
      "EndpointPath": "/internal/openclaw/bridge/invoke",
      "BearerToken": "",
      "EnablePromptEchoFallback": true,
      "TimeoutSeconds": 60,
      "InternalBridge": {
        "Url": "http://127.0.0.1:5187",
        "RoutePath": "/internal/openclaw/bridge/invoke"
      }
    },
    "Telegram": {
      "BotToken": "",
      "ChatId": "",
      "DisableWebPagePreview": true,
      "UseWebhook": false,
      "WebhookSecret": "",
      "EnablePolling": true,
      "PollingTimeoutSeconds": 30,
      "PollingLimit": 20,
      "PollingOffsetStateFilePath": "memory/telegram-polling-state.json"
    }
  }
}
